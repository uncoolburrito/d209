# ----------------------------------------------------------------------------
# Wasim env vars
# ----------------------------------------------------------------------------
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit secrets.
# ----------------------------------------------------------------------------

# Supabase project URL and anon key.
# Find them in your Supabase dashboard:
#   Project Settings → API
#     - "Project URL"             -> NEXT_PUBLIC_SUPABASE_URL
#     - "Project API keys → anon" -> NEXT_PUBLIC_SUPABASE_ANON_KEY
# The anon key is safe to expose to the browser (it only grants what RLS allows).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Origin where this app is served. Used to build email-link redirect URLs.
# Local dev:    http://localhost:3000
# Vercel prod:  https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
